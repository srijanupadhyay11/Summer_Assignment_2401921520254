class Solution {

    int ans = 0;

    public int diameterOfBinaryTree(TreeNode root) {

        height(root);
        return ans;
    }

    public int height(TreeNode root) {

        if (root == null) {
            return 0;
        }

        int left = height(root.left);
        int right = height(root.right);

        if (left + right > ans) {
            ans = left + right;
        }

        if (left > right) {
            return left + 1;
        } else {
            return right + 1;
        }
    }
}
