class Solution {
    public int maxProfit(int[] p) {
        int min = p[0];
        int ans = 0;
        for (int i = 1; i < p.length; i++) {
            if (p[i] < min) {
                min = p[i];
            }
            int prof = p[i] - min;
            if (prof > ans) {
                ans = prof;
            }
        }
        return ans;
    }
}
